{
  "name": "@walwal-harness/cli",
  "version": "5.3.2",
  "description": "Production harness for AI agent engineering — Solo/Team mode, Planner, Generator(BE/FE), Evaluator(Func/Visual), optional Brainstormer. Supports React, Next.js, and Flutter FE stacks.",
  "bin": {
    "walwal-harness": "bin/init.js"
  },
  "scripts": {
    "postinstall": "node bin/init.js --auto",
    "init": "node bin/init.js",
    "scan": "bash scripts/scan-project.sh .",
    "reset": "node bin/init.js --force"
  },
  "keywords": [
    "harness-engineering",
    "ai-agent",
    "claude-code",
    "codex",
    "skill",
    "command",
    "solo-mode",
    "team-mode",
    "brainstorming",
    "planner",
    "generator",
    "evaluator",
    "nestjs",
    "react",
    "flutter",
    "playwright"
  ],
  "author": "",
  "license": "MIT",
  "files": [
    "bin/",
    "skills/",
    "scripts/",
    "commands/",
    "assets/",
    "gotchas/"
  ]
}
